# AEMR production env — копируйте как .env.production и заполните реальными значениями.
# НЕ коммитить .env.production в git (он в .gitignore).

# ===== Server =====
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# ===== Database =====
SQLITE_PATH=/app/data/aemr.db

# ===== Authentication (включить для публичного деплоя!) =====
# Сгенерировать: openssl rand -base64 32
AEMR_API_KEY=

# ===== Google Sheets API =====
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ===== Caddy edge =====
# ":80" — без TLS, доступ только по IP / http://193.233.244.217
# "aemr.your-domain.ru" — TLS Let's Encrypt включится автоматически
DOMAIN=:80
