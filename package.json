{
  "name": "aemr-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "concurrently \"pnpm -F @aemr/server dev\" \"pnpm -F @aemr/web dev\"",
    "build": "pnpm -r build",
    "build:server": "pnpm -F @aemr/server build",
    "build:web": "pnpm -F @aemr/web build",
    "start": "pnpm -F @aemr/server start",
    "db:generate": "pnpm -F @aemr/server db:generate",
    "db:migrate": "pnpm -F @aemr/server db:migrate",
    "db:studio": "pnpm -F @aemr/server db:studio",
    "lint": "eslint .",
    "lint:biome": "biome lint .",
    "biome:check": "biome check .",
    "biome:check:fix": "biome check --write .",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "format:biome": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "typecheck:all": "pnpm -r --workspace-concurrency=1 exec tsc --noEmit",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r --parallel test --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.1.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.1"
  }
}
